---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Not Found - TimeHopper">
	<main class="container error-page">
		<div class="content">
			<h1>404</h1>
			<h2>Page Not Found</h2>
			<p>Oops! The page you're looking for doesn't exist or has been moved.</p>
			<a href="/" class="btn">Back to Home</a>
		</div>
	</main>
</Layout>

<style>
	.error-page {
		height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.content h1 {
		font-size: 8rem;
		margin: 0;
		background: linear-gradient(to right, #fcc934, #fd547a, #526ea1);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		line-height: 1;
	}

	.content h2 {
		font-size: 2rem;
		margin: 0 0 1rem;
		color: #2c3e50;
	}

	.content p {
		font-size: 1.2rem;
		color: #666;
		margin-bottom: 2rem;
	}

	.btn {
		display: inline-block;
		background: #fd547a;
		color: white;
		padding: 12px 24px;
		border-radius: 50px;
		text-decoration: none;
		font-weight: bold;
		transition: transform 0.2s;
	}

	.btn:hover {
		transform: translateY(-2px);
		text-decoration: none;
	}
</style>
