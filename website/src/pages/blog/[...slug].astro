---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import sources from '../../data/sources.json';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const publishedPosts = posts.filter((post) => post.data.pubDate <= new Date());
	return publishedPosts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

const articleData = {
	"headline": post.data.title,
	"description": post.data.description,
	"image": post.data.heroImage ? [post.data.heroImage] : [],
	"datePublished": post.data.pubDate.toISOString(),
	"author": [{
		"@type": "Person",
		"name": "Dan Walsh",
		"url": "https://timehopperapp.com"
	}]
};

const breadcrumbs = [
	{ name: 'Home', item: '/index.html' },
	{ name: 'Blog', item: '/blog.html' },
	{ name: post.data.title, item: `/blog/${post.slug}.html` }
];
---

<Layout 
	title={`${post.data.title} - TimeHopper Blog`} 
	description={post.data.description}
	ogType="article"
	image={post.data.heroImage}
	breadcrumbs={breadcrumbs}
>
	<JsonLd type="Article" data={articleData} />
	
	<article class="container blog-post">
		<header>
			<div class="meta">
				<time datetime={post.data.pubDate.toISOString()}>
					{post.data.pubDate.toLocaleDateString('en-us', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>
			</div>
			<h1>{post.data.title}</h1>
			{post.data.heroImage && <img src={post.data.heroImage} alt="" class="hero-img" />}
		</header>
		
		<div class="content">
			<Content />
		</div>

		{post.data.sources && post.data.sources.length > 0 && (
			<section class="sources-section">
				<hr />
				<h2>Sources</h2>
				<ul>
					{post.data.sources.map(sourceId => {
						const source = sources[sourceId];
						return source ? (
							<li>
								<a href={source.url} target="_blank" rel="noopener noreferrer">
									{source.title}
								</a>
								{source.publisher && <span class="publisher"> ({source.publisher})</span>}
							</li>
						) : null;
					})}
				</ul>
			</section>
		)}

		<RelatedPosts currentPost={post} />

		<footer>
			<a href="/blog.html">&larr; Back to blog</a>
		</footer>
	</article>
</Layout>

<style is:global>
	.blog-post {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 20px;
	}

	.blog-post header {
		margin-bottom: 40px;
		text-align: center;
	}

	.blog-post .meta {
		color: #888;
		margin-bottom: 1rem;
	}

	.blog-post h1 {
		font-size: 3rem;
		line-height: 1.1;
		margin: 0 0 2rem;
		color: #2c3e50;
	}

	.blog-post .hero-img {
		width: 100%;
		border-radius: 12px;
		margin-top: 2rem;
	}

	.blog-post .content {
		font-size: 1.2rem;
		line-height: 1.8;
		color: #333;
	}

	.blog-post .content h2 {
		margin-top: 3rem;
		font-size: 2rem;
		color: #2c3e50;
	}

	.blog-post .content p {
		margin-bottom: 1.5rem;
	}

	.blog-post footer {
		margin-top: 60px;
		padding-top: 30px;
		border-top: 1px solid #eee;
	}

	/* Answer Box Styles */
	.answer-box {
		background: #fff8e1;
		border-left: 4px solid #fcc934;
		padding: 20px 30px;
		border-radius: 0 8px 8px 0;
		margin: 2rem 0;
	}

	.answer-box h3 {
		margin-top: 0;
		font-size: 1.2rem;
		color: #856404;
	}
</style>
