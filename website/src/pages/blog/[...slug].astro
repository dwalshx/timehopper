---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import JsonLd from '../../components/JsonLd.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import sources from '../../data/sources.json';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const publishedPosts = posts.filter((post) => post.data.pubDate <= new Date());
	return publishedPosts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();

const articleData = {
	"headline": post.data.title,
	"description": post.data.description,
	"image": post.data.heroImage ? [post.data.heroImage] : [],
	"datePublished": post.data.pubDate.toISOString(),
	"author": [{
		"@type": "Person",
		"name": "Dan Walsh",
		"url": "https://timehopperapp.com"
	}]
};

const breadcrumbs = [
	{ name: 'Home', item: '/index.html' },
	{ name: 'Blog', item: '/blog.html' },
	{ name: post.data.title, item: `/blog/${post.slug}.html` }
];
---

<Layout 
	title={`${post.data.title} - TimeHopper Blog`} 
	description={post.data.description}
	ogType="article"
	image={post.data.heroImage}
	breadcrumbs={breadcrumbs}
>
	<JsonLd type="Article" data={articleData} />
	
	<article class="container blog-post">
		<header>
			<div class="meta">
				<time datetime={post.data.pubDate.toISOString()}>
					{post.data.pubDate.toLocaleDateString('en-us', {
						year: 'numeric',
						month: 'long',
						day: 'numeric',
					})}
				</time>
			</div>

			{post.data.heroImage && <img src={post.data.heroImage} alt="" class="hero-img" />}
		</header>
		
		<div class="content">
			<Content />
		</div>

		{post.data.sources && post.data.sources.length > 0 && (
			<section class="sources-section">
				<hr />
				<h2>Sources</h2>
				<ul>
					{post.data.sources.map(sourceId => {
						const source = sources[sourceId];
						return source ? (
							<li>
								<a href={source.url} target="_blank" rel="noopener noreferrer">
									{source.title}
								</a>
								{source.publisher && <span class="publisher"> ({source.publisher})</span>}
							</li>
						) : null;
					})}
				</ul>
			</section>
		)}

		<RelatedPosts currentPost={post} />

		<footer>
			<a href="/blog.html">&larr; Back to blog</a>
		</footer>
	</article>
</Layout>

<style is:global>
	.blog-post {
		max-width: 800px;
		margin: 0 auto;
		padding: 60px 20px;
	}

	.blog-post header {
		margin-bottom: 40px;
		text-align: center;
	}

	.blog-post .meta {
		color: #888;
		margin-bottom: 1rem;
	}

	.blog-post h1 {
		text-align: center;
		font-size: 3rem;
		line-height: 1.1;
		margin: 0 0 2rem;
		color: #2c3e50;
	}

	.blog-post .hero-img {
		width: 100%;
		border-radius: 12px;
		margin-top: 2rem;
	}

	.blog-post .content {
		font-size: 1.2rem;
		line-height: 1.8;
		color: #333;
	}

	.blog-post .content h2 {
		margin-top: 3rem;
		font-size: 2rem;
		color: #2c3e50;
	}

	.blog-post .content p {
		margin-bottom: 1.5rem;
	}

	.blog-post footer {
		margin-top: 60px;
		padding-top: 30px;
		border-top: 1px solid #eee;
	}

	/* Blockquote Styles (standard markdown >) */
	.blog-post .content blockquote {
		border-left: 3px solid #cbd5e1;
		margin: 2rem 0;
		padding: 0.5rem 0 0.5rem 1.5rem;
		color: #475569;
		font-style: italic;
	}

	.blog-post .content blockquote p {
		margin-bottom: 0.75rem;
	}

	.blog-post .content blockquote p:last-child {
		margin-bottom: 0;
	}

	/* Pull Quote Styles */
	.blog-post .content .pull-quote {
		border-left: none;
		border-top: 2px solid #fd547a;
		border-bottom: 2px solid #fd547a;
		margin: 3rem 0;
		padding: 2rem 1.5rem;
		text-align: center;
		font-style: normal;
		color: #2c3e50;
	}

	.blog-post .content .pull-quote p {
		font-size: 1.5rem;
		line-height: 1.4;
		font-weight: 500;
		margin-bottom: 0;
	}

	@media (max-width: 768px) {
		.blog-post .content .pull-quote {
			margin: 2rem 0;
			padding: 1.5rem 1rem;
		}

		.blog-post .content .pull-quote p {
			font-size: 1.25rem;
		}
	}

	/* Answer Box Styles */
	.answer-box {
		background: #fff8e1;
		border-left: 4px solid #fcc934;
		padding: 20px 30px;
		border-radius: 0 8px 8px 0;
		margin: 2rem 0;
	}

	.answer-box h3 {
		margin-top: 0;
		font-size: 1.2rem;
		color: #856404;
	}

	/* Blog Table Styles */
	.blog-post .content table {
		width: 100%;
		border-collapse: separate;
		border-spacing: 0;
		margin: 1.5rem 0 2rem;
		font-size: 0.95rem;
		line-height: 1.5;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid #e2e8f0;
	}

	.blog-post .content thead {
		background: #f8fafc;
	}

	.blog-post .content th {
		padding: 12px 16px;
		text-align: left;
		font-weight: 600;
		color: #2c3e50;
		border-bottom: 2px solid #e2e8f0;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.blog-post .content td {
		padding: 12px 16px;
		border-bottom: 1px solid #f1f5f9;
		vertical-align: top;
		color: #475569;
	}

	.blog-post .content tbody tr:last-child td {
		border-bottom: none;
	}

	.blog-post .content tbody tr:hover {
		background: #f8fafc;
	}

	.blog-post .content td strong {
		color: #2c3e50;
	}

	.blog-post .content td code {
		font-size: 0.85em;
		background: #f1f5f9;
		padding: 2px 6px;
		border-radius: 4px;
		color: #334155;
	}

	/* Responsive table: horizontal scroll on small screens */
	@media (max-width: 768px) {
		.blog-post .content table {
			display: block;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
		}

		.blog-post .content th,
		.blog-post .content td {
			min-width: 140px;
			padding: 10px 12px;
			font-size: 0.9rem;
		}
	}

	/* Sources section styling */
	.sources-section h2 {
		font-size: 1.4rem;
		color: #64748b;
	}

	.sources-section ul {
		list-style: none;
		padding: 0;
	}

	.sources-section li {
		padding: 6px 0;
	}

	.sources-section .publisher {
		color: #94a3b8;
		font-size: 0.9rem;
	}
</style>
