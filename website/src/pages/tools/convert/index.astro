---
import Layout from '../../../layouts/Layout.astro';
import { pairs } from '../../../data/timezone-pairs';

const breadcrumbs = [
  { name: 'Home', item: '/index.html' },
  { name: 'Time Zone Converter', item: '/tools/convert.html' },
];

// Group pairs by "from" zone
const grouped = pairs.reduce((acc, pair) => {
  const key = pair.from.abbr;
  if (!acc[key]) acc[key] = [];
  acc[key].push(pair);
  return acc;
}, {} as Record<string, typeof pairs>);
---

<Layout
  title="Time Zone Converter — Convert Times Between Any Zone — TimeHopper"
  description="Convert times between time zones instantly. Quick converters for PST to EST, UTC to EST, GMT to PST, IST to EST, and 20+ popular zone pairs."
  breadcrumbs={breadcrumbs}
>
  <main class="converter-index">
    <div class="index-header">
      <div class="container">
        <h1>Time Zone Converter</h1>
        <p class="subtitle">Select a conversion pair to see live times, full conversion tables, and DST rules.</p>
      </div>
    </div>

    <div class="container">
      <div class="pairs-grid">
        {pairs.map(pair => (
          <a href={`/tools/convert/${pair.slug}.html`} class="pair-card">
            <div class="pair-zones">
              <span class="zone-from">{pair.from.abbr}</span>
              <span class="zone-arrow">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10M10 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="zone-to">{pair.to.abbr}</span>
            </div>
            <div class="pair-name">{pair.from.region} to {pair.to.region}</div>
            <div class="pair-meta">
              <span class="pair-offset">
                {Math.abs(pair.to.stdOffset - pair.from.stdOffset)} hour{Math.abs(pair.to.stdOffset - pair.from.stdOffset) !== 1 ? 's' : ''} difference
              </span>
              {(pair.from.hasDST || pair.to.hasDST) && <span class="pair-dst-tag">DST</span>}
            </div>
          </a>
        ))}
      </div>

      <section class="how-it-works">
        <h2>How to use this converter</h2>
        <p>Each converter page shows:</p>
        <div class="features-grid">
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div>
              <strong>Live clocks</strong>
              <span>Current time in both zones, updated every second</span>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <strong>Interactive converter</strong>
              <span>Select any hour and see the converted time instantly</span>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="3" y="3" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 7h14M7 3v14" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <div>
              <strong>Full conversion table</strong>
              <span>All 24 hours mapped between zones</span>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M10 1v2M10 17v2M3.93 3.93l1.42 1.42M14.65 14.65l1.42 1.42M1 10h2M17 10h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </div>
            <div>
              <strong>DST rules</strong>
              <span>When offsets change and what to watch for</span>
            </div>
          </div>
        </div>
        <p class="cta-text">
          For a more permanent solution, <a href="/blog/add-secondary-time-zone-google-calendar.html">add a secondary time zone to Google Calendar</a>
          so you always see both zones side by side. Or install
          <a href="https://chromewebstore.google.com/detail/timehopper-calendar-clock/jckljcbopecepadagmnjbfjgojpnfkhl">TimeHopper</a>
          to see multiple time zones in your browser toolbar without switching tabs.
        </p>
      </section>
    </div>
  </main>
</Layout>

<style>
  .converter-index {
    padding-bottom: 60px;
  }

  /* ── Header ── */
  .index-header {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-bottom: 1px solid #e2e8f0;
    padding: 48px 0 56px;
    text-align: center;
  }

  .index-header h1 {
    font-size: 2.6rem;
    color: #1e293b;
    margin: 0 0 8px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: #94a3b8;
    font-size: 1.1rem;
    margin: 0;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  /* ── Pairs Grid ── */
  .pairs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 12px;
    margin: 36px 0 48px;
  }

  .pair-card {
    display: block;
    padding: 20px 22px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    text-decoration: none !important;
    transition: all 0.2s;
    position: relative;
  }

  .pair-card:hover {
    border-color: #fd547a;
    box-shadow: 0 4px 16px rgba(253, 84, 122, 0.1);
    transform: translateY(-2px);
  }

  .pair-zones {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .zone-from, .zone-to {
    font-size: 1.4rem;
    font-weight: 800;
    color: #1e293b;
    letter-spacing: -0.01em;
  }

  .zone-arrow {
    color: #cbd5e1;
    display: flex;
    align-items: center;
  }

  .pair-card:hover .zone-arrow {
    color: #fd547a;
  }

  .pair-name {
    font-size: 0.82rem;
    color: #94a3b8;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .pair-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pair-offset {
    font-size: 0.78rem;
    color: #cbd5e1;
    font-weight: 500;
  }

  .pair-dst-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #f59e0b;
    background: #fffbeb;
    border: 1px solid #fde68a;
    padding: 1px 6px;
    border-radius: 4px;
  }

  /* ── How It Works ── */
  .how-it-works {
    border-top: 1px solid #f1f5f9;
    padding-top: 3rem;
  }

  .how-it-works h2 {
    font-size: 1.4rem;
    color: #1e293b;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .how-it-works > p {
    color: #94a3b8;
    font-size: 0.95rem;
    margin-bottom: 20px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-bottom: 2rem;
  }

  .feature {
    display: flex;
    gap: 14px;
    padding: 16px 18px;
    background: #f8fafc;
    border-radius: 10px;
    border: 1px solid #f1f5f9;
  }

  .feature-icon {
    color: #fd547a;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .feature strong {
    display: block;
    font-size: 0.9rem;
    color: #1e293b;
    margin-bottom: 2px;
  }

  .feature span {
    font-size: 0.82rem;
    color: #94a3b8;
    line-height: 1.4;
  }

  .cta-text {
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .index-header h1 {
      font-size: 1.8rem;
    }

    .index-header {
      padding: 32px 0 40px;
    }

    .pairs-grid {
      grid-template-columns: 1fr;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
