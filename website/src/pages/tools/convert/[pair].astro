    padding: 0 20px 18px;
    color: #64748b;
    line-height: 1.65;
    margin: 0;
    font-size: 0.95rem;
  }

  /* ── Related Conversions ── */
  .related-conversions {
    margin: 3rem 0;
  }

  .related-conversions h2 {
    font-size: 1.2rem;
    color: #1e293b;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .related-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .related-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    text-decoration: none !important;
    transition: all 0.15s;
  }

  .related-link:hover {
    border-color: #fd547a;
    background: #fff;
    box-shadow: 0 2px 8px rgba(253, 84, 122, 0.08);
  }

  .related-from {
    font-weight: 700;
    color: #475569;
    font-size: 0.9rem;
  }

  .related-link svg {
    color: #cbd5e1;
  }

  .related-link:hover svg {
    color: #fd547a;
  }

  .related-to {
    font-weight: 700;
    color: #475569;
    font-size: 0.9rem;
  }

  /* ── Blog Links ── */
  .blog-links {
    margin: 3rem 0;
    padding-top: 2rem;
    border-top: 1px solid #f1f5f9;
  }

  .blog-links h2 {
    font-size: 1.1rem;
    color: #94a3b8;
    margin-bottom: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.85rem;
  }

  .blog-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-links li {
    padding: 8px 0;
    border-bottom: 1px solid #f8fafc;
  }

  .blog-links li:last-child {
    border-bottom: none;
  }

  .blog-links a {
    font-size: 0.95rem;
    color: #475569 !important;
    transition: color 0.15s;
  }

  .blog-links a:hover {
    color: #fd547a !important;
  }

  /* ── Embed CTA ── */
  .embed-cta {
    margin-top: 12px;
    text-align: right;
  }

  .embed-button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
