<section class="support-cta">
	<div class="container">
		<div class="cta-card">
			<div class="cta-content">
				<h2>Stop doing time zone mental math.</h2>
				<p>Join thousands of remote professionals using TimeHopper to coordinate across continents effortlessly.</p>
				<div class="cta-actions">
					<a href="https://chromewebstore.google.com/detail/timehopper-effortless-tim/fdbmmaofgpcaglohaddoedbkcadjdjnl" class="cta-btn">
						<img src="/images/icon48.png" alt="" class="btn-icon">
						Add to Chrome - Free
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.support-cta {
		padding: 60px 0;
		background: #f9f9f9;
	}

	.cta-card {
		background: linear-gradient(135deg, #fd547a 0%, #526ea1 100%);
		border-radius: 24px;
		padding: 60px 40px;
		text-align: center;
		color: white;
		box-shadow: 0 20px 40px rgba(253, 84, 122, 0.2);
		position: relative;
		overflow: hidden;
	}

	.cta-card::before {
		content: '';
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
		pointer-events: none;
	}

	.cta-content {
		position: relative;
		z-index: 1;
		max-width: 600px;
		margin: 0 auto;
	}

	.cta-card h2 {
		font-size: 2.5rem;
		margin: 0 0 1rem;
		color: white;
		font-weight: 800;
	}

	.cta-card p {
		font-size: 1.25rem;
		opacity: 0.9;
		margin-bottom: 2.5rem;
		line-height: 1.5;
	}

	.cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		background: white;
		color: #fd547a !important;
		padding: 18px 36px;
		border-radius: 50px;
		font-weight: 700;
		font-size: 1.1rem;
		box-shadow: 0 10px 20px rgba(0,0,0,0.1);
		transition: transform 0.2s, box-shadow 0.2s;
		text-decoration: none;
	}

	.cta-btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 15px 30px rgba(0,0,0,0.15);
		text-decoration: none;
	}

	.btn-icon {
		width: 24px;
		height: 24px;
	}

	@media (max-width: 600px) {
		.cta-card {
			padding: 40px 20px;
		}
		.cta-card h2 {
			font-size: 1.8rem;
		}
		.cta-card p {
			font-size: 1.1rem;
		}
	}
</style>
