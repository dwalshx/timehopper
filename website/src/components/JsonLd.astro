---
interface Props {
  type: 'Organization' | 'WebSite' | 'Article' | 'BreadcrumbList';
  data: object;
}

const { type, data } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": type,
  ...data
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
