---
import { timezoneZones, formatOffsetLabel, type TimezoneZone } from '../data/timezone-zones';

// SVG layout constants
const SVG_WIDTH = 1200;
const SVG_HEIGHT = 600;
const TOTAL_BANDS = timezoneZones.length; // 39
const BAND_WIDTH = SVG_WIDTH / TOTAL_BANDS; // ~30.77px

// Compute x position for each band
const bandPositions = timezoneZones.map((_, index) => index * BAND_WIDTH);

// Color gradient: cool-to-warm from UTC-12 (left) to UTC+14 (right)
// Hue interpolates from 210 (cool deep blue) to 15 (warm burnt orange)
// Saturation and lightness stay in dark-theme range
function computeBandColor(index: number): string {
  const t = index / (TOTAL_BANDS - 1); // 0..1
  const hue = Math.round(210 - t * (210 - 15)); // 210 → 15
  const saturation = Math.round(60 + t * 10);   // 60% → 70%
  const lightness = Math.round(25 + t * 10);    // 25% → 35%
  return `hsl(${hue}, ${saturation}%, ${lightness}%)`;
}

const bandColors: string[] = timezoneZones.map((_, index) => computeBandColor(index));

// Text centering: x at band center
const textCenters = timezoneZones.map((_, index) => index * BAND_WIDTH + BAND_WIDTH / 2);

// 10 representative zones that get visible live clocks
const CLOCK_ZONES = new Set([
  'Pacific/Honolulu',      // HST, UTC-10
  'America/Los_Angeles',   // PST, UTC-8
  'America/Chicago',       // CST, UTC-6
  'America/New_York',      // EST, UTC-5
  'Europe/London',         // GMT, UTC+0
  'Europe/Berlin',         // CET, UTC+1
  'Asia/Dubai',            // GST, UTC+4
  'Asia/Kolkata',          // IST, UTC+5:30
  'Asia/Tokyo',            // JST, UTC+9
  'Pacific/Auckland',      // NZST, UTC+12
]);
---

<div class="world-map-container">
  <svg
    viewBox={`0 0 ${SVG_WIDTH} ${SVG_HEIGHT}`}
    preserveAspectRatio="xMidYMid meet"
    role="img"
    aria-label="World timezone map showing all UTC offset zones"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Dark background -->
    <rect width={SVG_WIDTH} height={SVG_HEIGHT} fill="#0f172a" />

    {timezoneZones.map((zone: TimezoneZone, index: number) => {
      const x = bandPositions[index];
      const cx = textCenters[index];
      const color = bandColors[index];
      const offsetLabel = formatOffsetLabel(zone.utcOffsetMinutes);

      return (
        <g
          data-tz={zone.iana}
          data-offset={zone.utcOffsetMinutes}
          data-abbr={zone.abbr}
          data-region={zone.region}
          data-pair={zone.converterPair || ''}
        >
          {/* Band fill */}
          <rect
            x={x}
            y={0}
            width={BAND_WIDTH}
            height={SVG_HEIGHT}
            fill={color}
          />
          {/* Separator line */}
          <line
            x1={x}
            y1={0}
            x2={x}
            y2={SVG_HEIGHT}
            stroke="rgba(255,255,255,0.08)"
            stroke-width="1"
          />
          {/* Zone abbreviation label */}
          <text
            x={cx}
            y={290}
            text-anchor="middle"
            dominant-baseline="middle"
            fill="rgba(255,255,255,0.85)"
            font-size="10"
            font-weight="700"
            font-family="system-ui, -apple-system, sans-serif"
          >
            {zone.abbr}
          </text>
          {/* UTC offset label */}
          <text
            x={cx}
            y={310}
            text-anchor="middle"
            dominant-baseline="middle"
            fill="rgba(255,255,255,0.5)"
            font-size="7.5"
            font-family="system-ui, -apple-system, sans-serif"
          >
            {offsetLabel}
          </text>
          {/* Live clock (only for selected representative zones) */}
          {CLOCK_ZONES.has(zone.iana) && (
            <text
              class="clock-time"
              x={cx}
              y={260}
              data-clock={zone.iana}
              text-anchor="middle"
              dominant-baseline="middle"
              fill="white"
              font-size="11"
              font-weight="700"
              font-family="system-ui, -apple-system, sans-serif"
              font-variant-numeric="tabular-nums"
            >
              --:--
            </text>
          )}
        </g>
      );
    })}
  </svg>

  <!-- Hover tooltip -->
  <div class="map-tooltip" id="map-tooltip" role="tooltip" aria-hidden="true">
    <div class="tooltip-abbr" id="tooltip-abbr"></div>
    <div class="tooltip-offset" id="tooltip-offset"></div>
    <div class="tooltip-region" id="tooltip-region"></div>
    <div class="tooltip-time" id="tooltip-time"></div>
  </div>

  <!-- Info panel for zones without converter pairs -->
  <div class="map-info-panel" id="map-info-panel" aria-hidden="true">
    <button class="info-panel-close" id="info-panel-close" aria-label="Close">&times;</button>
    <div class="info-panel-abbr" id="info-panel-abbr"></div>
    <div class="info-panel-offset" id="info-panel-offset"></div>
    <div class="info-panel-region" id="info-panel-region"></div>
    <div class="info-panel-time" id="info-panel-time"></div>
  </div>
</div>

<script>
  function initWorldMapClocks() {
    const clockEls = document.querySelectorAll('[data-clock]');
    if (clockEls.length === 0) return;

    function formatClockTime(date, iana) {
      return date.toLocaleTimeString('en-US', {
        timeZone: iana,
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      });
    }

    function updateAllClocks() {
      const now = new Date();
      clockEls.forEach(function(el) {
        var iana = el.getAttribute('data-clock');
        el.textContent = formatClockTime(now, iana);
      });
    }

    // Initial update immediately
    updateAllClocks();

    // Single shared timer — per MAP-03, no per-zone intervals
    var timerId = setInterval(updateAllClocks, 1000);

    // Page Visibility API: pause when tab hidden, resume when visible
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) {
        if (timerId !== null) {
          clearInterval(timerId);
          timerId = null;
        }
      } else {
        updateAllClocks(); // Immediate refresh on return
        if (timerId === null) {
          timerId = setInterval(updateAllClocks, 1000);
        }
      }
    });
  }

  function initWorldMapInteractivity() {
    const svg = document.querySelector('.world-map-container svg');
    if (!svg) return;

    const tooltip = document.getElementById('map-tooltip');
    const tooltipAbbr = document.getElementById('tooltip-abbr');
    const tooltipOffset = document.getElementById('tooltip-offset');
    const tooltipRegion = document.getElementById('tooltip-region');
    const tooltipTime = document.getElementById('tooltip-time');

    const infoPanel = document.getElementById('map-info-panel');
    const infoPanelAbbr = document.getElementById('info-panel-abbr');
    const infoPanelOffset = document.getElementById('info-panel-offset');
    const infoPanelRegion = document.getElementById('info-panel-region');
    const infoPanelTime = document.getElementById('info-panel-time');
    var infoPanelIana = null;

    document.getElementById('info-panel-close').addEventListener('click', function() {
      infoPanel.setAttribute('aria-hidden', 'true');
      infoPanelIana = null;
    });

    function findZoneGroup(target) {
      var el = target;
      while (el && el !== svg) {
        if (el.tagName === 'g' && el.hasAttribute('data-tz')) return el;
        el = el.parentElement;
      }
      return null;
    }

    function formatOffset(minutes) {
      var sign = minutes >= 0 ? '+' : '-';
      var abs = Math.abs(minutes);
      var h = Math.floor(abs / 60);
      var m = abs % 60;
      return 'UTC' + sign + h + (m > 0 ? ':' + String(m).padStart(2, '0') : '');
    }

    function getLiveTime(iana) {
      return new Date().toLocaleTimeString('en-US', {
        timeZone: iana,
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
      });
    }

    // Single event delegation on SVG root — INT-03
    svg.addEventListener('mousemove', function(e) {
      var group = findZoneGroup(e.target);
      if (!group) {
        tooltip.setAttribute('aria-hidden', 'true');
        return;
      }
      var iana = group.getAttribute('data-tz');
      var abbr = group.getAttribute('data-abbr');
      var offset = parseInt(group.getAttribute('data-offset'), 10);
      var region = group.getAttribute('data-region');

      tooltipAbbr.textContent = abbr;
      tooltipOffset.textContent = formatOffset(offset);
      tooltipRegion.textContent = region;
      tooltipTime.textContent = getLiveTime(iana);
      tooltip.setAttribute('aria-hidden', 'false');

      // Position tooltip near cursor
      var containerRect = svg.closest('.world-map-container').getBoundingClientRect();
      var x = e.clientX - containerRect.left + 12;
      var y = e.clientY - containerRect.top - 10;

      // Keep tooltip within container
      if (x + 160 > containerRect.width) x = x - 180;
      if (y < 10) y = 10;

      tooltip.style.left = x + 'px';
      tooltip.style.top = y + 'px';
    });

    svg.addEventListener('mouseleave', function() {
      tooltip.setAttribute('aria-hidden', 'true');
    });

    // Click handler — INT-02
    svg.addEventListener('click', function(e) {
      var group = findZoneGroup(e.target);
      if (!group) return;

      var pair = group.getAttribute('data-pair');
      if (pair) {
        // Navigate to converter page
        window.location.href = '/tools/convert/' + pair + '.html';
      } else {
        // Show info panel for zones without converter pairs — no dead ends
        var iana = group.getAttribute('data-tz');
        var abbr = group.getAttribute('data-abbr');
        var offset = parseInt(group.getAttribute('data-offset'), 10);
        var region = group.getAttribute('data-region');

        infoPanelAbbr.textContent = abbr;
        infoPanelOffset.textContent = formatOffset(offset);
        infoPanelRegion.textContent = region;
        infoPanelTime.textContent = getLiveTime(iana);
        infoPanelIana = iana;
        infoPanel.setAttribute('aria-hidden', 'false');
      }
    });

    // Keep info panel time updated using the shared clock timer
    setInterval(function() {
      if (infoPanelIana && infoPanel.getAttribute('aria-hidden') === 'false') {
        infoPanelTime.textContent = getLiveTime(infoPanelIana);
      }
    }, 1000);
  }

  // DOMContentLoaded dual-init pattern (matches TimezoneConverter)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initWorldMapClocks();
      initWorldMapInteractivity();
    });
  } else {
    initWorldMapClocks();
    initWorldMapInteractivity();
  }
</script>

<style>
  .world-map-container {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(15, 23, 42, 0.4);
    background: #0f172a;
  }

  .world-map-container svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .clock-time {
    font-variant-numeric: tabular-nums;
    transition: opacity 0.15s ease;
  }

  /* Hover cursor for clickable bands */
  .world-map-container svg g[data-tz] {
    cursor: pointer;
  }

  .world-map-container svg g[data-tz]:hover rect {
    filter: brightness(1.3);
    transition: filter 0.15s ease;
  }

  /* Tooltip */
  .map-tooltip {
    position: absolute;
    pointer-events: none;
    background: #1e293b;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    padding: 10px 14px;
    min-width: 140px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    z-index: 10;
    transition: opacity 0.12s ease;
  }

  .map-tooltip[aria-hidden="true"] {
    opacity: 0;
    pointer-events: none;
  }

  .map-tooltip[aria-hidden="false"] {
    opacity: 1;
  }

  .tooltip-abbr {
    color: #fd547a;
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 2px;
  }

  .tooltip-offset {
    color: rgba(255,255,255,0.6);
    font-size: 12px;
    margin-bottom: 4px;
  }

  .tooltip-region {
    color: rgba(255,255,255,0.85);
    font-size: 13px;
    margin-bottom: 4px;
  }

  .tooltip-time {
    color: white;
    font-size: 16px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  /* Info panel (for zones without converter pair) */
  .map-info-panel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #1e293b;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 12px;
    padding: 20px 28px;
    min-width: 200px;
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    z-index: 20;
    transition: opacity 0.15s ease;
  }

  .map-info-panel[aria-hidden="true"] {
    opacity: 0;
    pointer-events: none;
  }

  .map-info-panel[aria-hidden="false"] {
    opacity: 1;
  }

  .info-panel-close {
    position: absolute;
    top: 8px;
    right: 12px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 20px;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
  }

  .info-panel-close:hover {
    color: white;
  }

  .info-panel-abbr {
    color: #fd547a;
    font-weight: 700;
    font-size: 22px;
    margin-bottom: 4px;
  }

  .info-panel-offset {
    color: rgba(255,255,255,0.6);
    font-size: 14px;
    margin-bottom: 6px;
  }

  .info-panel-region {
    color: rgba(255,255,255,0.85);
    font-size: 15px;
    margin-bottom: 8px;
  }

  .info-panel-time {
    color: white;
    font-size: 28px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
</style>
